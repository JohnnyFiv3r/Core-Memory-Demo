APP_ENV=dev
ALLOWED_ORIGIN=http://localhost:5173

# Local eval defaults (set to true only when wiring Auth0/admin gating)
DEMO_AUTH_ENABLED=false
DEMO_AUTH_PUBLIC_READ_ENDPOINTS=true

CORE_MEMORY_ROOT=./var/core-memory
CORE_MEMORY_DEMO_BENCHMARK_ROOT=./var/core-memory-bench
CORE_MEMORY_DEMO_ARTIFACTS_ROOT=./var/core-memory-artifacts

# Optional: force model selection for chat endpoint
DEMO_MODEL_ID=
DEMO_CONTEXT_BUDGET=128000

# Heavy-operation gate
# Set to 0 to disable global cap and scope heavy concurrency per client identity instead.
ABUSE_HEAVY_MAX_CONCURRENT=0
ABUSE_HEAVY_MAX_CONCURRENT_PER_IDENTITY=1

# Model keys (one or more)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Benchmark / LoCoMo data source
# CORE_MEMORY_LOCOMO_DATA_FILE=/absolute/path/to/locomo/data/locomo10.json
# CORE_MEMORY_LOCOMO_REPO_ROOT=/absolute/path/to/locomo

# Optional semantic embedding configuration for benchmark runs.
# If unset, LoCoMo benchmark runs default to a deterministic local hash embedding
# provider inside the isolated benchmark root so readiness runs still work without
# external embedding credentials. Set one of the API keys above and override this
# if you want provider-backed embeddings instead.
# CORE_MEMORY_EMBEDDINGS_PROVIDER=hash
# CORE_MEMORY_EMBEDDINGS_MODEL=
