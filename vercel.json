{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd frontend && npm install --include=dev",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' blob: https://cdn.auth0.com https://esm.sh; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://core-memory-demo.onrender.com https://*.auth0.com https://cdn.auth0.com https://esm.sh https://cdn.jsdelivr.net; frame-src 'self' https://*.auth0.com"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://core-memory-demo.onrender.com/api/:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://core-memory-demo.onrender.com/v1/:path*"
    },
    {
      "source": "/chat",
      "destination": "/chat.html"
    },
    {
      "source": "/chris-demo.html",
      "destination": "/chat.html"
    },
    {
      "source": "/reagraph-archive.html",
      "destination": "/graph.html"
    },
    {
      "source": "/graph",
      "destination": "/graph.html"
    }
  ]
}
